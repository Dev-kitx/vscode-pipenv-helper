{
  "name": "pipenv-helper",
  "displayName": "Pipenv Helper",
  "description": "PyCharm-like Pipenv UX: detect Pipfile, create/sync env, set interpreter, prompt on lock changes.",
  "version": "0.1.2",
  "publisher": "Dev-kitx",
    "repository": {
        "type": "git",
        "url": "https://github.com/Dev-kitx/vscode-pipenv-helper"
    },
    "bugs": {
        "url": "https://github.com/Dev-kitx/vscode-pipenv-helper/issues"
    },
    "homepage": "https://github.com/Dev-kitx/vscode-pipenv-helper#readme",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "pricing": "Free",
  "activationEvents": [
    "workspaceContains:Pipfile"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "pipenvPackages",
          "name": "Pipenv Packages"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pipenvHelper.refreshPackages",
          "when": "view == pipenvPackages",
          "group": "navigation@2"
        },
        {
          "command": "pipenvHelper.addPackage",
          "when": "view == pipenvPackages",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "pipenvHelper.addPackage",
          "when": "view == pipenvPackages && viewItem == category",
          "group": "inline"
        },
        {
          "command": "pipenvHelper.uninstallPackage",
          "when": "view == pipenvPackages && (viewItem == package || viewItem == devPackage)",
          "group": "inline"
        }
      ]
    },
    "commands": [
      {
        "command": "pipenvHelper.setup",
        "title": "Pipenv: Setup (Create/Select Env + Sync)"
      },
      {
        "command": "pipenvHelper.lock",
        "title": "Pipenv: Lock Dependencies"
      },
      {
        "command": "pipenvHelper.sync",
        "title": "Pipenv: Sync Environment (Install from Lock)"
      },
      {
        "command": "pipenvHelper.selectInterpreter",
        "title": "Pipenv: Use Pipenv Interpreter"
      },
      {
        "command": "pipenvHelper.statusActions",
        "title": "Pipenv: Status Actions"
      },
      {
        "command": "pipenvHelper.activateVenv",
        "title": "Pipenv: Activate Environment in Terminal"
      },
      {
        "command": "pipenvHelper.check",
        "title": "Pipenv: Check Vulnerabilities"
      },
      {
        "command": "pipenvHelper.update",
        "title": "Pipenv: Update Packages"
      },
      {
        "command": "pipenvHelper.clean",
        "title": "Pipenv: Clean Unused Packages"
      },
      {
        "command": "pipenvHelper.exportRequirements",
        "title": "Pipenv: Export requirements.txt"
      },
      {
        "command": "pipenvHelper.openPipfile",
        "title": "Pipenv: Open Pipfile"
      },
      {
        "command": "pipenvHelper.showInfo",
        "title": "Pipenv: Environment Info"
      },
      {
        "command": "pipenvHelper.refreshPackages",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "pipenvHelper.addPackage",
        "title": "Add Package",
        "icon": "$(add)"
      },
      {
        "command": "pipenvHelper.uninstallPackage",
        "title": "Uninstall",
        "icon": "$(trash)"
      }
    ],
    "configuration": {
      "title": "Pipenv Helper",
      "properties": {
        "pipenvHelper.autoPromptOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Prompt to setup Pipenv when a workspace with Pipfile is opened."
        },
        "pipenvHelper.autoPromptOnChange": {
          "type": "boolean",
          "default": true,
          "description": "Prompt to lock/sync when Pipfile or Pipfile.lock changes."
        },
        "pipenvHelper.preferLockfile": {
          "type": "boolean",
          "default": true,
          "description": "Prefer Pipfile.lock (pipenv sync) over Pipfile install."
        },
        "pipenvHelper.showPythonVersion": {
          "type": "boolean",
          "default": true,
          "description": "Show the Python version in the status bar (e.g. Pipenv 3.11  synced)."
        },
        "pipenvHelper.autoLockOnPipfileSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run pipenv lock when Pipfile is saved, without prompting."
        },
        "pipenvHelper.pipenvPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the pipenv executable. Leave empty to auto-detect. Use this if pipenv is not found (run 'which pipenv' in your terminal to get the path)."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc -p . --noEmit",
    "bundle": "node esbuild.js",
    "vscode:prepublish": "npm run typecheck && npm run bundle",
    "watch": "tsc -watch -p .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "vscode",
    "extension",
    "pipenv",
    "python",
    "virtualenv",
    "dependency management",
    "dev tools"
  ],
  "author": "akashb",
  "license": "MIT",
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  }
}
